# ==========================================
# AZURE OPENAI CONFIGURATION
# ==========================================
# Copy this file to .env and fill in your Azure OpenAI credentials.
# Get these from: https://portal.azure.com → Azure AI Services → Your Resource → Keys and Endpoint

AZURE_OPENAI_ENDPOINT="https://YOUR_RESOURCE_NAME.openai.azure.com"
AZURE_OPENAI_API_KEY="your-api-key-here"
AZURE_OPENAI_API_VERSION="2024-08-01-preview"

# The deployment name of your model in Azure AI Studio / Azure AI Foundry
# Recommended: GPT-4o-mini or GPT-5 Nano
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-4o-mini"
